{
  "version": "5.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nickschot/ember-mobile-menu"
  },
  "workspaces": [
    "ember-mobile-menu",
    "docs",
    "test-app"
  ],
  "scripts": {
    "build": "pnpm --filter ember-mobile-menu build",
    "changelog": "npx lerna-changelog --from=v0.1.0-alpha.5 > CHANGELOG.md",
    "lint": "pnpm --filter '!docs' lint",
    "lint:fix": "pnpm --filter '!docs' lint:fix",
    "prepare": "pnpm build",
    "start": "concurrently 'pnpm:start:*' --restart-after 5000 --prefixColors auto",
    "start:addon": "pnpm --filter ember-mobile-menu start --no-watch.clearScreen",
    "start:docs": "pnpm --filter docs start",
    "start:test-app": "pnpm --filter test-app start",
    "test": "pnpm --filter '*' test",
    "test:ember": "pnpm --filter '*' test:ember"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "prettier": "3.8.2",
    "prettier-plugin-ember-template-tag": "2.1.4",
    "release-plan": "0.17.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "overrides": {
      "@ember/test-helpers": "5.4.1",
      "@ember/test-waiters": "4.1.1",
      "@handlebars/parser": "2.0.0"
    },
    "patchedDependencies": {
      "ember-app-scheduler": "patches/ember-app-scheduler.patch"
    },
    "packageExtensions": {
      "@ember/render-modifiers": {
        "peerDependencies": {
          "ember-source": "*"
        }
      },
      "ember-app-scheduler": {
        "dependencies": {
          "@ember/test-waiters": "*",
          "ember-auto-import": "*"
        }
      },
      "ember-tether": {
        "peerDependencies": {
          "ember-source": "*"
        }
      }
    }
  }
}
